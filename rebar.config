{erl_opts, [
    debug_info,
    warnings_as_errors
]}.

{deps, [
    {rocksdb, "2.4.1"},
    {hackney, "1.20.1"},
    %% Clustering support (optional, loaded on demand)
    {ra, "2.15.0"},        %% Raft consensus (includes gen_batch_server, aten)
    {cowboy, "2.12.0"}     %% HTTP API (optional)
]}.

{project_plugins, [
    rebar3_hex,
    rebar3_ex_doc
]}.

%% EUnit configuration
{eunit_opts, [verbose]}.
{cover_enabled, true}.

%% Shell configuration for development
{shell, [
    {apps, [barrel_vectordb]}
]}.

%% Dialyzer configuration
{dialyzer, [
    {warnings, [
        unmatched_returns,
        error_handling,
        unknown
    ]},
    {plt_extra_apps, [rocksdb, hackney, ra, cowboy, aten, gen_batch_server]},
    %% Exclude FAISS backend module - barrel_faiss is an optional dependency
    %% Exclude metrics module - prometheus is an optional dependency
    {exclude_mods, [barrel_vectordb_index_faiss, barrel_vectordb_metrics]}
]}.

%% HexDocs configuration
{hex, [{doc, ex_doc}]}.

{ex_doc, [
    {name, "barrel_vectordb"},
    {source_url, <<"https://gitlab.enki.io/barrel/barrel_vectordb">>},
    {homepage_url, <<"https://hex.pm/packages/barrel_vectordb">>},
    {extras, [<<"README.md">>, <<"CHANGELOG.md">>, <<"LICENSE">>]},
    {main, <<"readme">>},
    {api_reference, true}
]}.

%% Release configuration
{relx, [
    {release, {barrel_vectordb, "1.3.1"}, [
        barrel_vectordb,
        sasl
    ]},
    {dev_mode, true},
    {include_erts, false},
    {extended_start_script, true},
    {sys_config, "config/sys.config"}
]}.

{profiles, [
    {prod, [
        {relx, [
            {dev_mode, false},
            {include_erts, true}
        ]}
    ]},
    {test, [
        {deps, [
            {meck, "0.9.2"}
        ]},
        {extra_src_dirs, ["test/integration"]}
    ]},
    {bench, [
        {erl_opts, [
            debug_info,
            {d, 'BENCHMARK'}
        ]},
        {extra_src_dirs, ["bench"]},
        {eunit_opts, [verbose, {report, {eunit_surefire, [{dir, "_build/bench/logs"}]}}]}
    ]},
    %% FAISS backend support (optional)
    %% Enable with: rebar3 as faiss compile
    {faiss, [
        {deps, [
            {barrel_faiss, {git, "https://gitlab.enki.io/barrel-db/barrel_faiss.git", {branch, "main"}}}
        ]}
    ]},
    %% Combined test profile with FAISS support
    {test_faiss, [
        {deps, [
            {meck, "0.9.2"},
            {barrel_faiss, {git, "https://gitlab.enki.io/barrel-db/barrel_faiss.git", {branch, "main"}}}
        ]},
        {extra_src_dirs, ["test/integration"]}
    ]},
    %% Benchmarks with FAISS support
    {bench_faiss, [
        {deps, [
            {barrel_faiss, {git, "https://gitlab.enki.io/barrel-db/barrel_faiss.git", {branch, "main"}}}
        ]},
        {erl_opts, [
            debug_info,
            {d, 'BENCHMARK'}
        ]},
        {extra_src_dirs, ["bench"]}
    ]}
]}.

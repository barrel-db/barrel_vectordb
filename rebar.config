{erl_opts, [
    debug_info,
    warnings_as_errors
]}.

{deps, [
    {barrel_embed, "2.2.1"},
    {rocksdb, "2.4.1"},
    {hackney, "3.2.1"},
    {iommap, "1.0.0"},
    %% Clustering support (optional, loaded on demand)
    {ra, "2.15.0"},        %% Raft consensus (includes gen_batch_server, aten)
    {cowboy, "2.12.0"}     %% HTTP API (optional)
]}.

{project_plugins, [
    rebar3_hex,
    rebar3_ex_doc
]}.

%% CMake-based NIF build
{pre_hooks, [
    {"(linux|darwin)", compile, "./do_cmake.sh"},
    {"(linux|darwin)", clean, "rm -rf _build/cmake priv/barrel_vectordb_nif.so"}
]}.

{post_hooks, [
    {"(linux|darwin)", compile, "cmake --build _build/cmake --parallel"}
]}.

%% EUnit configuration
{eunit_opts, [verbose]}.
{cover_enabled, true}.

%% Shell configuration for development
{shell, [
    {apps, [barrel_vectordb]}
]}.

%% Xref configuration
{xref_checks, [
    undefined_function_calls,
    undefined_functions,
    locals_not_used
]}.
{xref_ignores, [
    %% Optional embedding support
    {barrel_embed, '_', '_'},
    %% Optional reranking support
    {barrel_rerank, '_', '_'},
    %% Optional FAISS backend
    {barrel_vectordb_index_faiss, '_', '_'},
    {barrel_faiss, '_', '_'},
    %% Optional enterprise module
    {barrel_vectordb_gateway_enterprise, '_', '_'},
    %% Benchmark modules
    {barrel_vectordb_bench, '_', '_'},
    {barrel_vectordb_hybrid_bench, '_', '_'},
    {bench_ranking, '_', '_'},
    {bench_normalized, '_', '_'},
    {bench_divergence, '_', '_'}
]}.

%% Dialyzer configuration
{dialyzer, [
    {warnings, [
        unmatched_returns,
        error_handling,
        unknown
    ]},
    {plt_extra_apps, [barrel_embed, rocksdb, hackney, ra, cowboy, aten, gen_batch_server, iommap]},
    %% Exclude FAISS backend module - barrel_faiss is an optional dependency
    %% Exclude benchmark modules - compiled without debug_info in bench profile
    {exclude_mods, [barrel_vectordb_index_faiss,
                    barrel_vectordb_bench, barrel_vectordb_hybrid_bench,
                    bench_ranking, bench_normalized, bench_divergence]}
]}.

%% HexDocs configuration
{hex, [{doc, ex_doc}]}.

{ex_doc, [
    {name, "barrel_vectordb"},
    {source_url, <<"https://gitlab.enki.io/barrel/barrel_vectordb">>},
    {homepage_url, <<"https://hex.pm/packages/barrel_vectordb">>},
    {extras, [<<"README.md">>, <<"CHANGELOG.md">>, <<"LICENSE">>]},
    {main, <<"readme">>},
    {api_reference, true}
]}.

%% Release configuration
{relx, [
    {release, {barrel_vectordb, "1.3.1"}, [
        barrel_vectordb,
        sasl
    ]},
    {dev_mode, true},
    {include_erts, false},
    {extended_start_script, true},
    {sys_config, "config/sys.config"}
]}.

{profiles, [
    {prod, [
        {relx, [
            {dev_mode, false},
            {include_erts, true}
        ]}
    ]},
    {test, [
        {deps, [
            {meck, "0.9.2"}
        ]},
        {extra_src_dirs, ["test/integration"]}
    ]},
    {bench, [
        {erl_opts, [
            debug_info,
            {d, 'BENCHMARK'}
        ]},
        {extra_src_dirs, ["bench"]},
        {eunit_opts, [verbose, {report, {eunit_surefire, [{dir, "_build/bench/logs"}]}}]}
    ]},
    %% Embedding support (optional)
    %% Enable with: rebar3 as embed compile
    {embed, [
        {deps, [
            {barrel_embed, "2.2.1"}
        ]}
    ]},
    %% Reranking support (optional)
    %% Enable with: rebar3 as rerank compile
    {rerank, [
        {deps, [
            {barrel_rerank, "0.1.1"}
        ]}
    ]},
    %% FAISS backend support (optional)
    %% Enable with: rebar3 as faiss compile
    {faiss, [
        {deps, [
            {barrel_faiss, "0.2.1"}
        ]}
    ]},
    %% Combined test profile with embed support
    {test_embed, [
        {deps, [
            {meck, "0.9.2"},
            {barrel_embed, "2.2.1"}
        ]},
        {extra_src_dirs, ["test/integration"]}
    ]},
    %% Combined test profile with FAISS support
    {test_faiss, [
        {deps, [
            {meck, "0.9.2"},
            {barrel_faiss, "0.2.1"}
        ]},
        {extra_src_dirs, ["test/integration"]}
    ]},
    %% Full test profile with all optional deps
    {test_full, [
        {deps, [
            {meck, "0.9.2"},
            {barrel_embed, "2.2.1"},
            {barrel_rerank, "0.1.1"},
            {barrel_faiss, "0.2.1"}
        ]},
        {extra_src_dirs, ["test/integration"]}
    ]},
    %% Benchmarks with FAISS support
    {bench_faiss, [
        {deps, [
            {barrel_faiss, "0.2.1"}
        ]},
        {erl_opts, [
            debug_info,
            {d, 'BENCHMARK'}
        ]},
        {extra_src_dirs, ["bench"]}
    ]}
]}.

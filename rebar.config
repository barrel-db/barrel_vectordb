{erl_opts, [
    debug_info,
    warnings_as_errors
]}.

{deps, [
    {rocksdb, "2.0.0"},
    {hackney, "1.20.1"},
    {jsx, "3.1.0"}
]}.

{project_plugins, [
    rebar3_hex,
    rebar3_ex_doc
]}.

%% EUnit configuration
{eunit_opts, [verbose]}.
{cover_enabled, true}.

%% Shell configuration for development
{shell, [
    {apps, [barrel_vectordb]}
]}.

%% Dialyzer configuration
{dialyzer, [
    {warnings, [
        unmatched_returns,
        error_handling,
        unknown
    ]},
    {plt_extra_apps, [rocksdb, hackney, jsx]}
]}.

%% HexDocs configuration
{hex, [{doc, ex_doc}]}.

{ex_doc, [
    {name, "barrel_vectordb"},
    {source_url, <<"https://gitlab.enki.io/barrel/barrel_vectordb">>},
    {homepage_url, <<"https://hex.pm/packages/barrel_vectordb">>},
    {extras, [<<"README.md">>, <<"LICENSE">>]},
    {main, <<"readme">>},
    {api_reference, true}
]}.

%% Release configuration
{relx, [
    {release, {barrel_vectordb, "1.0.0"}, [
        barrel_vectordb,
        sasl
    ]},
    {dev_mode, true},
    {include_erts, false},
    {extended_start_script, true},
    {sys_config, "config/sys.config"}
]}.

{profiles, [
    {prod, [
        {relx, [
            {dev_mode, false},
            {include_erts, true}
        ]}
    ]},
    {test, [
        {deps, [
            {meck, "0.9.2"}
        ]},
        {extra_src_dirs, ["test/integration"]}
    ]},
    {bench, [
        {erl_opts, [
            debug_info,
            {d, 'BENCHMARK'}
        ]},
        {extra_src_dirs, ["bench"]},
        {eunit_opts, [verbose, {report, {eunit_surefire, [{dir, "_build/bench/logs"}]}}]}
    ]}
]}.

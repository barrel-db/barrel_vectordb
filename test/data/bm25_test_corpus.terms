%% ============================================================
%% ERLANG/OTP (docs 1-20)
%% ============================================================
{<<"doc1">>, <<"Erlang is a functional programming language designed for building concurrent and fault-tolerant systems with high availability">>},
{<<"doc2">>, <<"The OTP framework provides behaviors like gen_server and supervisor for building robust Erlang applications">>},
{<<"doc3">>, <<"Erlang processes are lightweight and communicate through asynchronous message passing without shared memory">>},
{<<"doc4">>, <<"Pattern matching in Erlang allows elegant handling of different message types and data structures">>},
{<<"doc5">>, <<"Hot code swapping in Erlang enables updating running systems without stopping them or losing state">>},
{<<"doc6">>, <<"Erlang supervision trees provide fault tolerance by monitoring child processes and restarting failed ones">>},
{<<"doc7">>, <<"The BEAM virtual machine executes Erlang bytecode and provides soft real-time garbage collection">>},
{<<"doc8">>, <<"ETS tables in Erlang provide concurrent in-memory storage with constant time lookups">>},
{<<"doc9">>, <<"GenServer is a behavior module that implements a generic server process in the OTP framework">>},
{<<"doc10">>, <<"Erlang binary syntax makes parsing network protocols and file formats straightforward">>},
{<<"doc11">>, <<"Mnesia is a distributed database management system written in Erlang with transactions">>},
{<<"doc12">>, <<"Erlang ports allow communication with external programs through standard input output">>},
{<<"doc13">>, <<"The Erlang scheduler distributes processes across available CPU cores automatically">>},
{<<"doc14">>, <<"Erlang NIFs native implemented functions allow calling C code for performance critical operations">>},
{<<"doc15">>, <<"Dialyzer performs static analysis on Erlang code to find type errors and unreachable code">>},
{<<"doc16">>, <<"Rebar3 is the standard build tool for Erlang projects managing dependencies and releases">>},
{<<"doc17">>, <<"Erlang records provide syntactic sugar for working with tuples as named fields">>},
{<<"doc18">>, <<"The gen_statem behavior implements finite state machines in Erlang OTP applications">>},
{<<"doc19">>, <<"Erlang distributed nodes can communicate transparently across network boundaries">>},
{<<"doc20">>, <<"Common Test is the testing framework included in OTP for unit and integration tests">>},

